{
    "name": "lester-barahona/drupal-dev-tools",
    "description": "Automated Drupal development tooling: coding standards, static analysis and git hooks for custom code.",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "composer-plugin-api": "^2.0",
        "phpro/grumphp": "^2.0",
        "drupal/coder": "^8.3",
        "squizlabs/php_codesniffer": "^3.7",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpstan/phpstan": "^1.10",
        "mglaman/phpstan-drupal": "^1.2",
        "phpstan/extension-installer": "^1.3"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "LesterBarahona\\DrupalDevTools\\": "src/"
        }
    },
    "extra": {
        "class": "LesterBarahona\\DrupalDevTools\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "phpro/grumphp": true
        }
    }
}
